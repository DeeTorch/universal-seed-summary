# USS Engine provider credentials
# Copy this file to .env and fill only the providers you use.
# Never commit a real .env file.

# OpenAI / ChatGPT Enterprise-compatible OpenAI API Platform
OPENAI_API_KEY=
# Optional custom gateway / enterprise endpoint
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_BASE_URL=https://gov.api.openai.com/v1

# Anthropic Claude
ANTHROPIC_API_KEY=
# ANTHROPIC_BASE_URL=https://api.anthropic.com/v1

# Google Gemini
GEMINI_API_KEY=
# Alternate supported alias:
# GOOGLE_API_KEY=
# GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta

# xAI Grok
XAI_API_KEY=
# XAI_BASE_URL=https://api.x.ai/v1

# Local Ollama
# Ollama normally needs no API key locally.
OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_API_KEY=
