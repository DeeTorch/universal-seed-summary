    "FrontMatter": {
      "additionalProperties": true,
      "description": "YAML front matter expected at the top of USS Markdown artifacts.",
      "properties": {
        "mode": {
          "$ref": "#/$defs/InvocationMode"
        },
        "protocol": {
          "default": "Universal Seed Summary Invoker",
          "title": "Protocol",
          "type": "string"
        },
        "protocol_version": {
          "default": "1.3",
          "title": "Protocol Version",
          "type": "string"
        },
        "timestamp": {
          "title": "Timestamp",
          "type": "string"
        },
        "source_thread_id": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Source Thread Id"
        },
        "tool_version": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Tool Version"
        }
      },
      "required": [
        "mode",
        "timestamp"
      ],
      "title": "FrontMatter",
      "type": "object"
    },
    "HeaderSection": {
      "properties": {
        "Thread_Archetype": {
          "title": "Thread Archetype",
          "type": "string"
        },
        "Ignition_Vector": {
          "title": "Ignition Vector",
          "type": "string"
        },
        "Focus_Domains": {
          "title": "Focus Domains",
          "type": "string"
