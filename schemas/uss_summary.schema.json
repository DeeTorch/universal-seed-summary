        "Unresolved_Queries",
        "Priority_Vectors",
        "Risk_Surfaces"
      ],
      "title": "OpenVectorsSection",
      "type": "object"
    },
    "ThreadTopologySection": {
      "properties": {
        "Parent_Threads": {
          "anyOf": [
