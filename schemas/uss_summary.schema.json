  "description": "Structured representation of a USS Markdown artifact.",
  "properties": {
    "frontmatter": {
      "$ref": "#/$defs/FrontMatter"
    },
    "header": {
      "$ref": "#/$defs/HeaderSection"
    },
    "failure_semantics": {
      "$ref": "#/$defs/FailureSemanticsSection"
    },
    "cosmic_core": {
      "$ref": "#/$defs/CosmicCoreSection"
    },
    "decisions_grafts": {
      "$ref": "#/$defs/DecisionsGraftsSection"
    },
    "open_vectors": {
      "$ref": "#/$defs/OpenVectorsSection"
    },
